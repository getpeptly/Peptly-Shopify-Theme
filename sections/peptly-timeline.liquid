{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section
  class="peptly-section peptly-timeline{% if section.settings.alt_bg %} peptly-timeline--alt{% endif %}"
  aria-label="{{ section.settings.heading }}"
>
  <div class="peptly-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="peptly-timeline__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <p class="peptly-timeline__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    <div class="peptly-timeline__list">
      {%- for block in section.blocks -%}
        <div class="peptly-timeline__item" {{ block.shopify_attributes }}>
          <div class="peptly-timeline__marker">
            <div class="peptly-timeline__dot"></div>
            {%- unless forloop.last -%}
              <div class="peptly-timeline__line"></div>
            {%- endunless -%}
          </div>
          <div class="peptly-timeline__content">
            <div class="peptly-timeline__period">{{ block.settings.period }}</div>
            <h3 class="peptly-timeline__title">{{ block.settings.title }}</h3>
            <p class="peptly-timeline__text">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .peptly-timeline {
    background-color: var(--peptly-bone);
    padding: 64px 0;
  }
  @media (min-width: 750px) {
    .peptly-timeline {
      padding: 80px 0;
    }
  }
  .peptly-timeline--alt {
    background-color: var(--peptly-bone-dark);
  }
  .peptly-timeline__heading {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    margin-bottom: 16px;
    max-width: 560px;
  }
  .peptly-timeline__intro {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--peptly-ink);
    opacity: 0.8;
    margin-bottom: 40px;
    max-width: 560px;
  }
  .peptly-timeline__list {
    max-width: 640px;
  }
  .peptly-timeline__item {
    display: flex;
    gap: 24px;
  }
  .peptly-timeline__marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
  }
  .peptly-timeline__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--peptly-copper);
    flex-shrink: 0;
    margin-top: 6px;
  }
  .peptly-timeline__line {
    width: 1px;
    flex-grow: 1;
    background-color: var(--peptly-mist);
  }
  .peptly-timeline__content {
    padding-bottom: 40px;
  }
  .peptly-timeline__item:last-child .peptly-timeline__content {
    padding-bottom: 0;
  }
  .peptly-timeline__period {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--peptly-copper);
    margin-bottom: 6px;
  }
  .peptly-timeline__title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--peptly-forest);
    margin-bottom: 6px;
  }
  .peptly-timeline__text {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--peptly-ink);
    opacity: 0.7;
  }
</style>

{% schema %}
{
  "name": "peptly timeline",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text (optional)"
    },
    {
      "type": "checkbox",
      "id": "alt_bg",
      "label": "Use alternate background",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Timeline item",
      "settings": [
        {
          "type": "text",
          "id": "period",
          "label": "Time period",
          "default": "week 1–2"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "PLACEHOLDER: milestone title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "PLACEHOLDER: what customers typically notice at this stage."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "peptly timeline"
    }
  ]
}
{% endschema %}
