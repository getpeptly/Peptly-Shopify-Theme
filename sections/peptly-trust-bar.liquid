{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section class="peptly-section peptly-trust-bar" aria-label="Trust statement">
  <div class="peptly-container">
    <p class="peptly-trust-bar__text">{{ section.settings.text }}</p>
  </div>
</section>

{% schema %}
{
  "name": "peptly trust bar",
  "tag": "div",
  "class": "peptly-trust-bar-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Trust bar text",
      "default": "physician-supervised. pharmacy-compounded. delivered to your door."
    }
  ],
  "presets": [
    {
      "name": "peptly trust bar"
    }
  ]
}
{% endschema %}
