{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section
  class="peptly-section peptly-team{% if section.settings.alt_bg %} peptly-team--alt{% endif %}"
  aria-label="{{ section.settings.heading }}"
>
  <div class="peptly-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="peptly-team__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="peptly-team__card">
      <div class="peptly-team__photo">
        {%- if section.settings.photo != blank -%}
          {{ section.settings.photo | image_url: width: 400 | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 750px) 200px, 160px',
            widths: '160, 200, 320, 400',
            alt: section.settings.name
          }}
        {%- else -%}
          {%- comment -%} PLACEHOLDER: add real headshot {%- endcomment -%}
          <div class="peptly-team__photo-placeholder"></div>
        {%- endif -%}
      </div>
      <div class="peptly-team__info">
        <h3 class="peptly-team__name">{{ section.settings.name }}</h3>
        {%- if section.settings.credentials != blank -%}
          <div class="peptly-team__credentials">{{ section.settings.credentials }}</div>
        {%- endif -%}
        <div class="peptly-team__bio">{{ section.settings.bio }}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .peptly-team {
    background-color: var(--peptly-bone);
    padding: 64px 0;
  }
  @media (min-width: 750px) {
    .peptly-team {
      padding: 80px 0;
    }
  }
  .peptly-team--alt {
    background-color: var(--peptly-bone-dark);
  }
  .peptly-team__heading {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    margin-bottom: 32px;
  }
  .peptly-team__card {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 640px;
  }
  @media (min-width: 750px) {
    .peptly-team__card {
      flex-direction: row;
      gap: 40px;
    }
  }
  .peptly-team__photo {
    flex-shrink: 0;
    width: 160px;
    height: 160px;
    border-radius: 12px;
    overflow: hidden;
  }
  @media (min-width: 750px) {
    .peptly-team__photo {
      width: 200px;
      height: 200px;
    }
  }
  .peptly-team__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .peptly-team__photo-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--peptly-mist);
  }
  .peptly-team__name {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--peptly-forest);
    margin-bottom: 4px;
  }
  .peptly-team__credentials {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--peptly-copper);
    margin-bottom: 16px;
  }
  .peptly-team__bio {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--peptly-ink);
    opacity: 0.8;
  }
  .peptly-team__bio p {
    margin-bottom: 12px;
  }
  .peptly-team__bio p:last-child {
    margin-bottom: 0;
  }
</style>

{% schema %}
{
  "name": "peptly team member",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "our medical director"
    },
    {
      "type": "image_picker",
      "id": "photo",
      "label": "Photo"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "PLACEHOLDER: Dr. [name]"
    },
    {
      "type": "text",
      "id": "credentials",
      "label": "Credentials",
      "default": "PLACEHOLDER: MD, board-certified in [specialty]"
    },
    {
      "type": "richtext",
      "id": "bio",
      "label": "Bio",
      "default": "<p>PLACEHOLDER: a paragraph about the medical director's background, training, and why they joined peptly.</p>"
    },
    {
      "type": "checkbox",
      "id": "alt_bg",
      "label": "Use alternate background",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "peptly team member"
    }
  ]
}
{% endschema %}
