{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section class="peptly-section peptly-steps" aria-label="{{ section.settings.heading }}">
  <div class="peptly-container">
    <h2 class="peptly-steps__heading">{{ section.settings.heading }}</h2>

    <div class="peptly-steps__grid">
      {%- for block in section.blocks -%}
        <div class="peptly-step" {{ block.shopify_attributes }}>
          <div class="peptly-step__number">{{ block.settings.number }}</div>
          <h3 class="peptly-step__title">{{ block.settings.title }}</h3>
          <p class="peptly-step__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "peptly steps",
  "tag": "div",
  "class": "peptly-steps-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "from questionnaire to delivery in under a week"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "take the questionnaire"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step description",
          "default": "5 minutes, online. we ask about your health history, goals, and current medications."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "peptly steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "take the questionnaire",
            "text": "5 minutes, online. we ask about your health history, goals, and current medications."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "title": "licensed physician reviews your case",
            "text": "a real physician reviews your questionnaire and determines if peptide therapy is appropriate for you."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "title": "compounded pharmacy fills your prescription",
            "text": "your prescription is filled by a verified compounding pharmacy with third-party purity testing."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "04",
            "title": "discreet delivery to your door",
            "text": "shipped in plain, temperature-controlled packaging. no branding on the outside."
          }
        }
      ]
    }
  ]
}
{% endschema %}
