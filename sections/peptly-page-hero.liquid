{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section class="peptly-section peptly-page-hero" aria-label="{{ section.settings.heading }}">
  <div class="peptly-container">
    {%- if section.settings.label != blank -%}
      <div class="peptly-page-hero__label">{{ section.settings.label }}</div>
    {%- endif -%}
    <h1 class="peptly-page-hero__heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="peptly-page-hero__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.price != blank -%}
      <div class="peptly-page-hero__price">{{ section.settings.price }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <div class="peptly-page-hero__actions">
        <a href="{{ section.settings.button_link }}" class="peptly-btn peptly-btn--primary peptly-btn--large">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .peptly-page-hero {
    background-color: var(--peptly-bone);
    padding: 80px 0 60px;
  }
  @media (min-width: 750px) {
    .peptly-page-hero {
      padding: 120px 0 80px;
    }
  }
  .peptly-page-hero__label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--peptly-copper);
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }
  .peptly-page-hero__heading {
    font-size: clamp(2rem, 5vw, 3rem);
    max-width: 640px;
    margin-bottom: 16px;
  }
  .peptly-page-hero__sub {
    font-size: clamp(1rem, 2vw, 1.125rem);
    max-width: 560px;
    margin-bottom: 24px;
    opacity: 0.8;
  }
  .peptly-page-hero__price {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--peptly-forest);
    margin-bottom: 32px;
  }
  .peptly-page-hero__actions {
    margin-top: 8px;
  }
</style>

{% schema %}
{
  "name": "peptly page hero",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Top label (optional)",
      "info": "Small text above the heading, e.g. protocol name"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "page title"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price text (optional)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "peptly page hero"
    }
  ]
}
{% endschema %}
