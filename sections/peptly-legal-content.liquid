{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section class="peptly-section peptly-legal" aria-label="{{ section.settings.heading }}">
  <div class="peptly-container">
    <h1 class="peptly-legal__heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.updated != blank -%}
      <p class="peptly-legal__updated">last updated: {{ section.settings.updated }}</p>
    {%- endif -%}
    <div class="peptly-legal__body">
      {{ section.settings.body }}
    </div>
  </div>
</section>

<style>
  .peptly-legal {
    background-color: var(--peptly-bone);
    padding: 80px 0;
  }
  @media (min-width: 750px) {
    .peptly-legal {
      padding: 120px 0 80px;
    }
  }
  .peptly-legal__heading {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: 8px;
    color: var(--peptly-forest);
  }
  .peptly-legal__updated {
    font-size: 0.8125rem;
    color: var(--peptly-ink);
    opacity: 0.5;
    margin-bottom: 40px;
  }
  .peptly-legal__body {
    max-width: 720px;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--peptly-ink);
  }
  .peptly-legal__body h2 {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--peptly-forest);
    margin: 40px 0 12px;
  }
  .peptly-legal__body h3 {
    font-size: 1rem;
    font-weight: 500;
    color: var(--peptly-forest);
    margin: 28px 0 8px;
  }
  .peptly-legal__body p {
    margin-bottom: 12px;
    max-width: 720px;
  }
  .peptly-legal__body p:last-child {
    margin-bottom: 0;
  }
  .peptly-legal__body strong {
    font-weight: 500;
  }
</style>

{% schema %}
{
  "name": "peptly legal content",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "legal page"
    },
    {
      "type": "text",
      "id": "updated",
      "label": "Last updated date",
      "default": "April 9, 2026"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Page content",
      "default": "<p>PLACEHOLDER: legal content here.</p>"
    }
  ],
  "presets": [
    {
      "name": "peptly legal content"
    }
  ]
}
{% endschema %}
