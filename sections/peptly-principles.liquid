{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section
  class="peptly-section peptly-principles{% if section.settings.alt_bg %} peptly-principles--alt{% endif %}"
  aria-label="{{ section.settings.heading }}"
>
  <div class="peptly-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="peptly-principles__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="peptly-principles__grid">
      {%- for block in section.blocks -%}
        <div class="peptly-principles__item" {{ block.shopify_attributes }}>
          <h3 class="peptly-principles__title">{{ block.settings.title }}</h3>
          <p class="peptly-principles__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .peptly-principles {
    background-color: var(--peptly-bone);
    padding: 64px 0;
  }
  @media (min-width: 750px) {
    .peptly-principles {
      padding: 80px 0;
    }
  }
  .peptly-principles--alt {
    background-color: var(--peptly-bone-dark);
  }
  .peptly-principles__heading {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    margin-bottom: 48px;
    max-width: 560px;
  }
  .peptly-principles__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 750px) {
    .peptly-principles__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
  }
  .peptly-principles__title {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--peptly-forest);
    margin-bottom: 8px;
  }
  .peptly-principles__text {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--peptly-ink);
    opacity: 0.8;
  }
</style>

{% schema %}
{
  "name": "peptly principles",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "what we believe"
    },
    {
      "type": "checkbox",
      "id": "alt_bg",
      "label": "Use alternate background",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "principle",
      "name": "Principle",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "PLACEHOLDER: principle title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "PLACEHOLDER: principle description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "peptly principles"
    }
  ]
}
{% endschema %}
