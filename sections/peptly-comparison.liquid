{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section class="peptly-section peptly-comparison" aria-label="{{ section.settings.heading }}">
  <div class="peptly-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="peptly-comparison__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="peptly-comparison__table-wrap">
      <table class="peptly-comparison__table" role="table">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col">{{ section.settings.col_1_name }}</th>
            <th scope="col">{{ section.settings.col_2_name }}</th>
            <th scope="col" class="peptly-comparison__highlight">{{ section.settings.col_3_name }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            <tr {{ block.shopify_attributes }}>
              <td class="peptly-comparison__row-label">{{ block.settings.row_label }}</td>
              <td>{{ block.settings.col_1 }}</td>
              <td>{{ block.settings.col_2 }}</td>
              <td class="peptly-comparison__highlight">{{ block.settings.col_3 }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .peptly-comparison {
    background-color: var(--peptly-bone-dark);
    padding: 64px 0;
  }
  @media (min-width: 750px) {
    .peptly-comparison {
      padding: 80px 0;
    }
  }
  .peptly-comparison__heading {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    margin-bottom: 40px;
  }
  .peptly-comparison__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .peptly-comparison__table {
    width: 100%;
    min-width: 600px;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .peptly-comparison__table thead th {
    font-weight: 500;
    color: var(--peptly-forest);
    text-align: left;
    padding: 12px 16px;
    border-bottom: 2px solid var(--peptly-mist);
    white-space: nowrap;
  }
  .peptly-comparison__table tbody td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--peptly-mist);
    color: var(--peptly-ink);
    line-height: 1.5;
  }
  .peptly-comparison__row-label {
    font-weight: 500;
    color: var(--peptly-forest);
    white-space: nowrap;
  }
  .peptly-comparison__highlight {
    background-color: rgba(31, 58, 46, 0.04);
  }
  thead .peptly-comparison__highlight {
    color: var(--peptly-copper);
  }
</style>

{% schema %}
{
  "name": "peptly comparison table",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "how peptly compares"
    },
    {
      "type": "text",
      "id": "col_1_name",
      "label": "Column 1 name",
      "default": "gray market"
    },
    {
      "type": "text",
      "id": "col_2_name",
      "label": "Column 2 name",
      "default": "concierge clinics"
    },
    {
      "type": "text",
      "id": "col_3_name",
      "label": "Column 3 name (highlighted)",
      "default": "peptly"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Table row",
      "settings": [
        {
          "type": "text",
          "id": "row_label",
          "label": "Row label",
          "default": "physician oversight"
        },
        {
          "type": "text",
          "id": "col_1",
          "label": "Column 1 value",
          "default": "none"
        },
        {
          "type": "text",
          "id": "col_2",
          "label": "Column 2 value",
          "default": "yes"
        },
        {
          "type": "text",
          "id": "col_3",
          "label": "Column 3 value (highlighted)",
          "default": "yes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "peptly comparison table",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "row_label": "physician oversight",
            "col_1": "none",
            "col_2": "yes",
            "col_3": "yes"
          }
        },
        {
          "type": "row",
          "settings": {
            "row_label": "pharmacy quality",
            "col_1": "unverified",
            "col_2": "compounded",
            "col_3": "compounded, third-party tested"
          }
        },
        {
          "type": "row",
          "settings": {
            "row_label": "monthly cost",
            "col_1": "$40–150",
            "col_2": "$500–1,500",
            "col_3": "$150–400"
          }
        },
        {
          "type": "row",
          "settings": {
            "row_label": "onboarding time",
            "col_1": "immediate (no review)",
            "col_2": "1–3 weeks",
            "col_3": "under 1 week"
          }
        },
        {
          "type": "row",
          "settings": {
            "row_label": "purity testing",
            "col_1": "none",
            "col_2": "varies",
            "col_3": "third-party COA on every batch"
          }
        }
      ]
    }
  ]
}
{% endschema %}
