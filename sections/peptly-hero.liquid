{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section class="peptly-section peptly-hero" aria-label="{{ section.settings.heading }}">
  <div class="peptly-hero__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        sizes: '100vw',
        widths: '375, 750, 1100, 1500, 1920',
        alt: section.settings.image_alt
      }}
    {%- else -%}
      {%- comment -%} PLACEHOLDER: Replace with editorial photography — man tying running shoes at sunrise, or a clean product shot of a vial photographed like a luxury good {%- endcomment -%}
      <div style="width:100%;height:100%;background-color:#2a4f3d;"></div>
    {%- endif -%}
  </div>
  <div class="peptly-hero__overlay"></div>

  <div class="peptly-hero__content">
    <h1>{{ section.settings.heading }}</h1>
    <p class="peptly-hero__sub">{{ section.settings.subheading }}</p>
    <div class="peptly-hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="peptly-btn peptly-btn--bone peptly-btn--large">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_label != blank -%}
        <a href="{{ section.settings.secondary_link }}" class="peptly-link peptly-link--bone">
          {{ section.settings.secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "peptly hero",
  "tag": "div",
  "class": "peptly-hero-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "recovery, prescribed."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "peptide therapy supervised by licensed physicians, compounded by verified pharmacies, delivered to your door. starting at $150/month."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "PLACEHOLDER: editorial lifestyle photography"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "see if peptly is right for you"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary link label",
      "default": "how it works"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link URL"
    }
  ],
  "presets": [
    {
      "name": "peptly hero"
    }
  ]
}
{% endschema %}
