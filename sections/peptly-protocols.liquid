{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section class="peptly-section peptly-protocols" aria-label="{{ section.settings.heading }}">
  <div class="peptly-container">
    <h2 class="peptly-protocols__heading">{{ section.settings.heading }}</h2>

    <div class="peptly-protocols__grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link }}"
          class="peptly-protocol-card"
          {{ block.shopify_attributes }}
          aria-label="{{ block.settings.name }} — {{ block.settings.description }}"
        >
          <h3 class="peptly-protocol-card__name">{{ block.settings.name }}</h3>
          <p class="peptly-protocol-card__desc">{{ block.settings.description }}</p>
          <div class="peptly-protocol-card__price">{{ block.settings.price }}</div>
          <span class="peptly-protocol-card__link">
            learn more
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "peptly protocols",
  "tag": "div",
  "class": "peptly-protocols-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "three protocols. one platform."
    }
  ],
  "blocks": [
    {
      "type": "protocol",
      "name": "Protocol card",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Protocol name",
          "default": "bpc-157"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description",
          "default": "for tissue repair and recovery."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price text",
          "default": "starting at $150/month"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Protocol page link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "peptly protocols",
      "blocks": [
        {
          "type": "protocol",
          "settings": {
            "name": "bpc-157",
            "description": "for tissue repair and recovery.",
            "price": "starting at $150/month"
          }
        },
        {
          "type": "protocol",
          "settings": {
            "name": "cjc-1295 / ipamorelin",
            "description": "for sleep, anti-aging, and longevity.",
            "price": "starting at $200/month"
          }
        },
        {
          "type": "protocol",
          "settings": {
            "name": "tb-500",
            "description": "for muscle repair and flexibility.",
            "price": "starting at $150/month"
          }
        }
      ]
    }
  ]
}
{% endschema %}
