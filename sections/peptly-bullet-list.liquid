{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section
  class="peptly-section peptly-bullets{% if section.settings.alt_bg %} peptly-bullets--alt{% endif %}"
  aria-label="{{ section.settings.heading }}"
>
  <div class="peptly-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="peptly-bullets__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <p class="peptly-bullets__intro">{{ section.settings.intro }}</p>
    {%- endif -%}
    <ul class="peptly-bullets__list" role="list">
      {%- for block in section.blocks -%}
        <li class="peptly-bullets__item" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

<style>
  .peptly-bullets {
    background-color: var(--peptly-bone);
    padding: 64px 0;
  }
  @media (min-width: 750px) {
    .peptly-bullets {
      padding: 80px 0;
    }
  }
  .peptly-bullets--alt {
    background-color: var(--peptly-bone-dark);
  }
  .peptly-bullets__heading {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    margin-bottom: 16px;
    max-width: 560px;
  }
  .peptly-bullets__intro {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--peptly-ink);
    opacity: 0.8;
    margin-bottom: 28px;
    max-width: 560px;
  }
  .peptly-bullets__list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 640px;
  }
  .peptly-bullets__item {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--peptly-ink);
    padding: 12px 0 12px 24px;
    position: relative;
    border-bottom: 1px solid var(--peptly-mist);
  }
  .peptly-bullets__item:last-child {
    border-bottom: none;
  }
  .peptly-bullets__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--peptly-copper);
  }
</style>

{% schema %}
{
  "name": "peptly bullet list",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text (optional)"
    },
    {
      "type": "checkbox",
      "id": "alt_bg",
      "label": "Use alternate background",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "List item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Item text",
          "default": "PLACEHOLDER: list item"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "peptly bullet list"
    }
  ]
}
{% endschema %}
