{{ 'peptly-custom.css' | asset_url | stylesheet_tag }}

<section class="peptly-section peptly-pricing" aria-label="{{ section.settings.heading }}">
  <div class="peptly-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="peptly-pricing__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="peptly-pricing__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="peptly-pricing__grid">
      {%- for block in section.blocks -%}
        <div class="peptly-pricing__card" {{ block.shopify_attributes }}>
          <div class="peptly-pricing__card-top">
            <h3 class="peptly-pricing__card-name">{{ block.settings.name }}</h3>
            <p class="peptly-pricing__card-desc">{{ block.settings.description }}</p>
          </div>
          <div class="peptly-pricing__card-price">
            <span class="peptly-pricing__amount">{{ block.settings.price }}</span>
            <span class="peptly-pricing__period">/month</span>
          </div>
          <ul class="peptly-pricing__includes" role="list">
            {%- if block.settings.include_1 != blank -%}
              <li>{{ block.settings.include_1 }}</li>
            {%- endif -%}
            {%- if block.settings.include_2 != blank -%}
              <li>{{ block.settings.include_2 }}</li>
            {%- endif -%}
            {%- if block.settings.include_3 != blank -%}
              <li>{{ block.settings.include_3 }}</li>
            {%- endif -%}
            {%- if block.settings.include_4 != blank -%}
              <li>{{ block.settings.include_4 }}</li>
            {%- endif -%}
            {%- if block.settings.include_5 != blank -%}
              <li>{{ block.settings.include_5 }}</li>
            {%- endif -%}
          </ul>
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="peptly-btn peptly-btn--primary" style="width:100%;text-align:center;">
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .peptly-pricing {
    background-color: var(--peptly-bone);
    padding: 80px 0;
  }
  @media (min-width: 750px) {
    .peptly-pricing {
      padding: 120px 0;
    }
  }
  .peptly-pricing__heading {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    margin-bottom: 12px;
  }
  .peptly-pricing__sub {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--peptly-ink);
    opacity: 0.7;
    margin-bottom: 48px;
    max-width: 480px;
  }
  .peptly-pricing__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 750px) {
    .peptly-pricing__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .peptly-pricing__card {
    background-color: var(--peptly-bone-dark);
    border: 1px solid var(--peptly-mist);
    border-radius: 12px;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
  }
  .peptly-pricing__card-top {
    flex-grow: 1;
  }
  .peptly-pricing__card-name {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--peptly-forest);
    margin-bottom: 6px;
  }
  .peptly-pricing__card-desc {
    font-size: 0.875rem;
    color: var(--peptly-ink);
    opacity: 0.7;
    line-height: 1.5;
    margin-bottom: 24px;
  }
  .peptly-pricing__card-price {
    margin-bottom: 24px;
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .peptly-pricing__amount {
    font-size: 2rem;
    font-weight: 500;
    color: var(--peptly-forest);
  }
  .peptly-pricing__period {
    font-size: 0.875rem;
    color: var(--peptly-ink);
    opacity: 0.5;
  }
  .peptly-pricing__includes {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
  }
  .peptly-pricing__includes li {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--peptly-ink);
    padding: 8px 0 8px 20px;
    position: relative;
    border-bottom: 1px solid rgba(212, 217, 210, 0.4);
  }
  .peptly-pricing__includes li:last-child {
    border-bottom: none;
  }
  .peptly-pricing__includes li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 8px;
    height: 4px;
    border-left: 1.5px solid var(--peptly-forest);
    border-bottom: 1.5px solid var(--peptly-forest);
    transform: rotate(-45deg);
  }
</style>

